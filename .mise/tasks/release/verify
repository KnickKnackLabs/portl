#!/usr/bin/env -S uv run --script
#MISE description="Verify Portl release metadata and optionally run release checks"
# /// script
# requires-python = ">=3.11"
# ///
from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import time
from collections.abc import Mapping
from pathlib import Path

FIRST_PARTY = {
    "docker-portl",
    "manual-portl",
    "portl-agent",
    "portl-cli",
    "portl-core",
    "portl-proto",
    "slicer-portl",
}
VERSION_RE = re.compile(r"^\d+\.\d+\.\d+$")


def run(
    cmd: list[str],
    *,
    capture: bool = False,
    env: Mapping[str, str] | None = None,
) -> subprocess.CompletedProcess[str]:
    print("$", " ".join(cmd))
    started = time.monotonic()
    try:
        return subprocess.run(cmd, text=True, capture_output=capture, check=True, env=env)
    finally:
        elapsed = time.monotonic() - started
        print(f"[release:verify] completed in {elapsed:.1f}s: {' '.join(cmd)}")


def repo_root() -> Path:
    return Path(subprocess.check_output(["git", "rev-parse", "--show-toplevel"], text=True).strip())


def workspace_version(root: Path) -> str:
    text = (root / "Cargo.toml").read_text()
    match = re.search(r"(?m)^version\s*=\s*\"(\d+\.\d+\.\d+)\"", text)
    if not match:
        raise SystemExit("Could not find workspace version")
    return match.group(1)


def first_party_lock_versions(root: Path) -> dict[str, str]:
    lock = (root / "Cargo.lock").read_text()
    versions: dict[str, str] = {}
    for block in lock.split("\n\n"):
        name = re.search(r'(?m)^name = "([^"]+)"', block)
        version = re.search(r'(?m)^version = "([^"]+)"', block)
        if name and version and name.group(1) in FIRST_PARTY:
            versions[name.group(1)] = version.group(1)
    return versions


def require(condition: bool, message: str) -> None:
    if not condition:
        raise SystemExit(message)


def verify_metadata(root: Path, version: str, allow_existing_tag: bool) -> None:
    require(workspace_version(root) == version, f"workspace version is not {version}")
    for name, found in sorted(first_party_lock_versions(root).items()):
        require(found == version, f"Cargo.lock {name} is {found}, expected {version}")
    changelog = (root / "CHANGELOG.md").read_text()
    heading = re.search(rf"(?m)^##\s+{re.escape(version)}\s+—\s+\d{{4}}-\d{{2}}-\d{{2}}$", changelog)
    require(bool(heading), f"CHANGELOG.md missing dated {version} heading")
    section = re.search(
        rf"(?ms)^##\s+{re.escape(version)}\s+—\s+\d{{4}}-\d{{2}}-\d{{2}}\n(?P<body>.*?)(?=^##\s+)",
        changelog,
    )
    require(bool(section and section.group("body").strip()), f"CHANGELOG.md {version} section is empty")
    readme = (root / "README.md").read_text()
    for needle in [f"PORTL_VERSION={version}", f"KnickKnackLabs/portl@{version}"]:
        require(needle in readme, f"README.md missing {needle}")
    metadata = json.loads(
        run(["cargo", "metadata", "--format-version", "1", "--no-deps"], capture=True).stdout
    )
    first_party_versions = {
        package["name"]: package["version"]
        for package in metadata["packages"]
        if package["name"] in FIRST_PARTY
    }
    for name in sorted(FIRST_PARTY):
        found = first_party_versions.get(name)
        require(found == version, f"cargo metadata {name} is {found}, expected {version}")
    local_tag = subprocess.run(["git", "rev-parse", "-q", "--verify", f"refs/tags/v{version}"], capture_output=True)
    if not allow_existing_tag:
        require(local_tag.returncode != 0, f"local tag v{version} already exists")


def require_tool(tool: str, install_hint: str) -> None:
    if shutil.which(tool) is None:
        raise SystemExit(f"Required command not found: {tool}. {install_hint}")


def nextest_env(*, temp_home: bool) -> dict[str, str]:
    env = os.environ.copy()
    env.setdefault("PORTL_TEST_WATCHDOG_SECS", "90")
    if temp_home:
        env["PORTL_HOME"] = tempfile.mkdtemp(prefix="portl-release-verify-")
    return env


def run_local_checks() -> None:
    require_tool("cargo-nextest", "Run `mise install` or `cargo install cargo-nextest`.")
    run(
        [
            "cargo",
            "nextest",
            "run",
            "--profile",
            "ci",
            "-p",
            "portl-cli",
            "--lib",
            "--status-level",
            "slow",
            "--final-status-level",
            "slow",
        ]
    )
    run(
        [
            "cargo",
            "nextest",
            "run",
            "--profile",
            "ci",
            "-p",
            "portl-core",
            "--lib",
            "--status-level",
            "slow",
            "--final-status-level",
            "slow",
        ]
    )
    run(
        [
            "cargo",
            "nextest",
            "run",
            "--profile",
            "ci",
            "-p",
            "portl-agent",
            "--lib",
            "--status-level",
            "slow",
            "--final-status-level",
            "slow",
        ]
    )
    run(["cargo", "clippy", "-p", "portl-cli", "-p", "portl-core", "--all-targets", "--", "-D", "warnings"])


def run_ci_checks() -> None:
    require_tool("cargo-nextest", "Run `mise install` or `cargo install cargo-nextest`.")
    run(
        [
            "cargo",
            "nextest",
            "run",
            "--profile",
            "ci",
            "--workspace",
            "--all-features",
            "--lib",
            "--bins",
            "--tests",
            "--status-level",
            "slow",
            "--final-status-level",
            "slow",
        ]
    )
    run(["cargo", "clippy", "--workspace", "--all-features", "--all-targets", "--", "-D", "warnings"])


def run_smoke_checks() -> None:
    require_tool("cargo-nextest", "Run `mise install` or `cargo install cargo-nextest`.")
    smoke_targets = [
        "endpoint_close_cli",
        "status_cli",
        "agent_run",
        "udp_cli",
        "m3_cli",
    ]
    cmd = [
        "cargo",
        "nextest",
        "run",
        "--profile",
        "ci",
        "-p",
        "portl-cli",
        "--status-level",
        "slow",
        "--final-status-level",
        "slow",
    ]
    for target in smoke_targets:
        cmd.extend(["--test", target])
    cmd.extend(["--run-ignored", "only"])
    run(cmd, env=nextest_env(temp_home=True))


def main() -> int:
    parser = argparse.ArgumentParser(description="Verify a Portl release")
    parser.add_argument("version")
    parser.add_argument("--local", action="store_true", help="Run fast local nextest and clippy checks")
    parser.add_argument("--ci", action="store_true", help="Run CI-equivalent nextest and clippy checks")
    parser.add_argument("--smoke", action="store_true", help="Run ignored release smoke tests with nextest")
    parser.add_argument("--full", action="store_true", help="Run --ci and --smoke")
    parser.add_argument("--skip-command-checks", action="store_true")
    parser.add_argument("--allow-existing-tag", action="store_true")
    args = parser.parse_args()
    if not VERSION_RE.match(args.version):
        raise SystemExit(f"Invalid version {args.version!r}; expected X.Y.Z")
    root = repo_root()
    verify_metadata(root, args.version, args.allow_existing_tag)
    if not args.skip_command_checks:
        run(["cargo", "fmt", "--check"])
        run(["git", "diff", "--check"])
        if args.full:
            args.ci = True
            args.smoke = True
        if args.local:
            run_local_checks()
        if args.ci:
            run_ci_checks()
        if args.smoke:
            run_smoke_checks()
    print(f"release metadata verified for v{args.version}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
